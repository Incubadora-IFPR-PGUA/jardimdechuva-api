PORT=3333
HOST=0.0.0.0
NODE_ENV=development
APP_KEY=gere_uma_chave_rodando_node_ace_generate_key
DRIVE_DISK=local
DB_CONNECTION=mysql

# Com túnel SSH ativo (deixe o terminal SSH aberto):
#   ssh -L 3307:127.0.0.1:3306 root@SEU_IP_VPS
# A porta LOCAL do -L (3307) deve ser igual a MYSQL_PORT abaixo.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=seu_usuario_mysql
MYSQL_PASSWORD=sua_senha_mysql
MYSQL_DB_NAME=seu_nome_do_banco

# MQTT — ESP32 publica no broker; a API escuta e grava no banco
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtts://url-do-seu-broker:8883
MQTT_USER=seu_usuario_mqtt
MQTT_PASSWORD=sua_senha_mqtt
# Tópicos separados por vírgula (um sensor no banco por tópico)
MQTT_TOPICS=sensor_esp,sensor_clima
